# =============================================================================
# Environment variables for the Bridge Bidding Assistant
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by pydantic-settings (in config.py).
# It is git-ignored so your secrets never end up in version control.
#
# In Docker, docker-compose.yml reads from this file automatically.
# Both SECRET_KEY and TUNNEL_TOKEN must be set before deploying.
# =============================================================================

# Secret key for signing JWT authentication tokens.
# MUST be changed in production -- anyone who knows this key can forge tokens.
# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=dev-secret-change-in-production

# SQLite database connection string. Relative paths are relative to the
# working directory where uvicorn is launched.
# In Docker, this points to a mounted volume so data persists:
#   DATABASE_URL=sqlite:///./data/bridge.db
DATABASE_URL=sqlite:///./bridge.db

# Logging level for the bridge.* logger hierarchy.
# INFO (default) logs HTTP requests and business events (session created,
# bid placed, etc.). DEBUG adds engine rule evaluation traces.
LOG_LEVEL=INFO

# CORS origins -- which domains are allowed to make cross-origin API calls.
# Only needed during development when the frontend and backend are on
# different ports (Vite at 5173, FastAPI at 8000).
# In production (single-origin serving via Docker), leave this empty:
#   CORS_ORIGINS=[]
CORS_ORIGINS=["http://localhost:5173"]

# Claude API key for LLM-powered explanations and alternative analysis.
# Optional -- the rule engine works without it.
ANTHROPIC_API_KEY=your-api-key-here

# Cloudflare Tunnel token for exposing the app at kibitzer.club.
# Get this from: Cloudflare dashboard -> Zero Trust -> Networks -> Tunnels
# Create a tunnel, then copy the token shown in the install instructions.
TUNNEL_TOKEN=your-tunnel-token-here
